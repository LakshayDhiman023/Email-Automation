# Backend API base URL.
VITE_API_BASE=http://localhost:8000

# Must match the backend's API_TOKEN in any public deployment (sent as X-API-Token).
# Leave empty for local dev when the backend has no API_TOKEN set.
VITE_API_TOKEN=

# Must match the backend's EXPORT_TOKEN to enable the "Export CSV" button.
VITE_EXPORT_TOKEN=
