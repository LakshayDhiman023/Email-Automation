# ---- Database (Supabase) ----
# Get this from Supabase: Project Settings → Database → Connection string (URI).
# Use the pooled "Transaction" connection string for a hosted app.
DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@[HOST]:5432/postgres

# ---- Gmail API (filled in Phase 2) ----
# From the OAuth client you create in Google Cloud Console.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Generated once locally via the OAuth consent flow, then stored here / as a host secret.
GMAIL_REFRESH_TOKEN=
# The Gmail address sends originate from (your account).
GMAIL_SENDER=your.email@gmail.com

# ---- App config ----
TIMEZONE=Asia/Kolkata
# Resume file attached to every outreach email.
RESUME_PATH=resume/Ved_Prakash_Meena_Resume.pdf
# Comma-separated origins allowed to call the API (your dashboard).
CORS_ORIGINS=http://localhost:5173

# ---- Scheduling windows (24h, local TIMEZONE) ----
WINDOW_A_START=09:00
WINDOW_A_END=10:00
WINDOW_B_START=14:00
WINDOW_B_END=15:00
# Working days only (Mon-Fri) + India public holidays are handled in code.
FOLLOWUP_AFTER_WORKING_DAYS=5
