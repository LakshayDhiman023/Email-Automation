# ---- Database (Supabase) ----
# Get this from Supabase: Project Settings → Database → Connection string (URI).
# Use the pooled "Transaction" connection string for a hosted app.
DATABASE_URL=postgresql+psycopg://postgres:[PASSWORD]@[HOST]:5432/postgres

# ---- Gmail API (filled in Phase 2) ----
# From the OAuth client you create in Google Cloud Console.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
# Generated once locally via the OAuth consent flow, then stored here / as a host secret.
GMAIL_REFRESH_TOKEN=
# The Gmail address sends originate from (your account).
GMAIL_SENDER=your.email@gmail.com

# ---- App config ----
TIMEZONE=Asia/Kolkata
# Resume file attached to every outreach email.
RESUME_PATH=resume/Ved-IIIT-Resume.pdf
# Comma-separated origins allowed to call the API (your dashboard).
CORS_ORIGINS=http://localhost:5173
# Shared secret guarding ALL app endpoints (frontend sends it as X-API-Token, and as
# VITE_API_TOKEN on the frontend). Empty = auth disabled (local dev only). MUST be set
# for any public deployment — the app can send email from your Gmail.
API_TOKEN=

# ---- Scheduling fallback defaults ----
# Timezone, send windows, working days and holidays are configured in-app on the
# Settings page (stored in the app_settings table) so each deployment can localize.
# These env values are only the fallback used before migration 003 runs / the row
# exists. TIMEZONE is any IANA name (e.g. America/New_York, Europe/London).
WINDOW_A_START=09:00
WINDOW_A_END=10:00
WINDOW_B_START=14:00
WINDOW_B_END=15:00
FOLLOWUP_AFTER_WORKING_DAYS=5

# ---- Deliverability & safety (Phase 8 hardening) ----
# Max emails actually sent per rolling 24h. Keeps a free Gmail account well under
# its limits so it isn't flagged/suspended. 0 = unlimited (not recommended).
DAILY_SEND_CAP=40
# Don't re-email the same address within this many days (across all threads). 0 = off.
CONTACT_COOLDOWN_DAYS=30
# Retry a transient Gmail error (rate limit / 5xx / network) up to this many times.
MAX_SEND_ATTEMPTS=3
# Shared secret to download the outreach CSV (all recruiter emails + bodies).
# Leave empty to DISABLE the export endpoint entirely (fail-closed). If set, the
# frontend must send the same value as VITE_EXPORT_TOKEN.
EXPORT_TOKEN=
